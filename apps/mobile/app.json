{
  "expo": {
    "name": "Трекер задач МКУ ЦБО",
    "slug": "treker-zadach-mku-cbo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/cbo_logo.png",
    "userInterfaceStyle": "light",
    "scheme": "mku-cbo-task-tracker",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mkucbo.tasktracker"
    },
    "android": {
      "package": "com.mkucbo.tasktracker",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/cbo_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/cbo_logo.png",
          "color": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
